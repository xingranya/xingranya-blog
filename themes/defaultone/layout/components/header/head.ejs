                                                                            <!--- Page Info (SEO优化：标题限制70字符内) -->
                                                                            <%
                                                                            let pageTitle = page.title;
                                                                            if (is_archive()) {
                                                                                pageTitle = __('archive');
                                                                                if (is_month()) {
                                                                                    pageTitle += ': ' + page.year + '/' + page.month;
                                                                                } else if (is_year()) {
                                                                                    pageTitle += ': ' + page.year;
                                                                                }
                                                                            } else if (is_category()) {
                                                                                pageTitle = __('category') + ': ' + page.category;
                                                                            } else if (is_tag()) {
                                                                                pageTitle = __('tag') + ': ' + page.tag;
                                                                            } else {
                                                                                pageTitle = __(page.title);
                                                                            }

                                                                            // SEO优化：构建完整标题并限制长度
                                                                            let siteName = theme.info.title || config.title || '星苒鸭博客';
                                                                            let fullTitle = '';
                                                                            if (pageTitle) {
                                                                                // 计算站点名称部分长度（包含分隔符）
                                                                                let sitePartLength = (' | ' + siteName).length;
                                                                                let maxPageTitleLength = 70 - sitePartLength;
                                                                                // 如果页面标题过长，截断
                                                                                if (pageTitle.length > maxPageTitleLength) {
                                                                                    pageTitle = pageTitle.substring(0, maxPageTitleLength - 3) + '...';
                                                                                }
                                                                                fullTitle = pageTitle + ' | ' + siteName;
                                                                            } else {
                                                                                let subtitle = theme.info.subtitle || config.subtitle || '';
                                                                                if (subtitle) {
                                                                                    fullTitle = siteName + ' - ' + subtitle;
                                                                                    if (fullTitle.length > 70) {
                                                                                        fullTitle = fullTitle.substring(0, 67) + '...';
                                                                                    }
                                                                                } else {
                                                                                    fullTitle = siteName;
                                                                                }
                                                                            }
                                                                            %>
