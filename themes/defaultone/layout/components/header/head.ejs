<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        html.redefine-style-loading {
            background: var(--redefine-loading-background, #202124);
        }

        html.redefine-style-loading body {
            visibility: hidden;
        }

        html.redefine-style-loading * {
            transition: none !important;
        }

        @media (prefers-color-scheme: light) {
            html.redefine-style-loading {
                background: var(--redefine-loading-background, #fff);
            }
        }
    </style>
    <noscript>
        <style>
            html.redefine-style-loading body {
                visibility: visible;
            }
        </style>
    </noscript>
    <script>
        (function () {
            var root = document.documentElement;
            var fallbackTimer;

            function setLoadingBackground() {
                try {
                    var themeStatus = JSON.parse(localStorage.getItem('REDEFINE-THEME-STATUS') || '{}');
                    var isDark = themeStatus && themeStatus.isDark;

                    if (isDark === undefined || isDark === null) {
                        isDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                    }

                    root.style.setProperty('--redefine-loading-background', isDark ? '#202124' : '#fff');
                } catch (error) {
                    root.style.setProperty('--redefine-loading-background', '#202124');
                }
            }

            window.redefineReleaseStyleLoading = function () {
                clearTimeout(fallbackTimer);
                root.classList.remove('redefine-style-loading');
                root.style.removeProperty('--redefine-loading-background');
            };

            window.redefineCriticalStyleReady = function (style) {
                if (style) {
                    style.setAttribute('data-redefine-style-loaded', 'true');
                }

                if (window.redefineReleaseWhenCriticalStylesReady) {
                    window.redefineReleaseWhenCriticalStylesReady();
                }
            };

            window.redefineReleaseWhenCriticalStylesReady = function () {
                var styles = document.querySelectorAll('link[data-redefine-critical-style]');
                var expectedCount = window.redefineCriticalStyleExpectedCount || 0;

                if (expectedCount && styles.length < expectedCount) {
                    return;
                }

                if (!expectedCount && !styles.length) {
                    window.redefineReleaseStyleLoading();
                    return;
                }

                for (var i = 0; i < styles.length; i++) {
                    var style = styles[i];

                    if (style.getAttribute('data-redefine-style-loaded') === 'true') {
                        continue;
                    }

                    if (style.sheet) {
                        style.setAttribute('data-redefine-style-loaded', 'true');
                        continue;
                    }

                    return;
                }

                window.redefineReleaseStyleLoading();
            };

            setLoadingBackground();
            root.classList.add('redefine-style-loading');
            fallbackTimer = setTimeout(window.redefineReleaseStyleLoading, 5000);
            document.addEventListener('DOMContentLoaded', window.redefineReleaseWhenCriticalStylesReady);
        })();
    </script>
    <script>
        window.redefineCriticalStyleExpectedCount = 2;
    </script>
    <%- css('css/style').replace('<link', '<link data-redefine-critical-style onload="window.redefineCriticalStyleReady&&window.redefineCriticalStyleReady(this)" onerror="window.redefineCriticalStyleReady&&window.redefineCriticalStyleReady(this)"') %>
    <% if (theme.developer && theme.developer.enable) { %>
        <%- css('css/build/tailwind.css').replace('<link', '<link data-redefine-critical-style onload="window.redefineCriticalStyleReady&&window.redefineCriticalStyleReady(this)" onerror="window.redefineCriticalStyleReady&&window.redefineCriticalStyleReady(this)"') %>
    <% } else { %>
        <%- renderCSS('css/build/tailwind.css').replace('<link', '<link data-redefine-critical-style onload="window.redefineCriticalStyleReady&&window.redefineCriticalStyleReady(this)" onerror="window.redefineCriticalStyleReady&&window.redefineCriticalStyleReady(this)"') %>
    <% } %>
    <script>
        window.redefineReleaseWhenCriticalStylesReady&&window.redefineReleaseWhenCriticalStylesReady();
    </script>
    <meta name="keywords" content="<%= page.keywords || config.keywords || 'Hexo Theme defaultone' %>">
    <% if (!theme.global.open_graph) { %>
        <%
        // SEO优化：确保 description 长度在 25-160 字符之间
        let seoDescription = page.description || page.excerpt || config.description || 'Hexo Theme defaultone';
        // 移除 HTML 标签
        seoDescription = seoDescription.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
        // 截断到 155 字符（留出余量）
        if (seoDescription.length > 155) {
            seoDescription = seoDescription.substring(0, 152) + '...';
        }
        // 如果太短，补充站点信息
        if (seoDescription.length < 25) {
            seoDescription = (config.title || '星苒鸭博客') + ' - ' + seoDescription;
        }
        %>
        <meta name="description" content="<%= seoDescription %>">
        <% }%>
            <meta name="author" content="<%= theme.info.author || config.author || 'defaultone Team' %>">
