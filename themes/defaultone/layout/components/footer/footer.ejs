<footer class="footer mt-5 h-auto text-base text-third-text-color relative border-t-2 border-t-border-color">
    <div class="info-container text-center" style="padding: 16px 0;">
        <div style="line-height:1.2;">
            &copy; <%= date(new Date(), 'YYYY' ) %> <a href="/"><%= theme.info.author || 'xingranya' %></a> | All rights reserved.
        </div>
        <div style="line-height:1.2; margin-top: 8px;">
            Powered by <a href="/"><%= theme.info.author || 'xingranya' %></a>
        </div>
        <% if (theme.footer.icp && theme.footer.icp.enable) { %>
        <div style="line-height:1.2; margin-top: 8px;">
            <a href="<%= theme.footer.icp.url || 'https://beian.miit.gov.cn/' %>" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: none;">
                <%= theme.footer.icp.number %>
            </a>
        </div>
        <% } %>
    </div>
</footer>
